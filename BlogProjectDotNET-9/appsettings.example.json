{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    // Option 1: SQL Server with Windows Authentication (LocalDB)
    "constr": "Data Source=.;Initial Catalog=BlogSiteDb;Integrated Security=True;Encrypt=True;TrustServerCertificate=True"

    // Option 2: SQL Server with username/password
    // "constr": "Server=YOUR_SERVER;Database=BlogSiteDb;User Id=YOUR_USERNAME;Password=YOUR_PASSWORD;Encrypt=True;TrustServerCertificate=True"

    // Option 3: SQL Server LocalDB
    // "constr": "Server=(localdb)\\mssqllocaldb;Database=BlogSiteDb;Trusted_Connection=True;"
  }
}
