@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@using BlogProjectDotNET_9.Helper
@model IEnumerable<Post>;
@{
    ViewData["Title"] = "Blog Posts";
    var currentCategory = HttpContextAccessor.HttpContext?.Request?.Query["categoryID"].ToString();
    var currentSearch = HttpContextAccessor.HttpContext?.Request?.Query["search"].ToString();
}

<!-- Hero Section -->
<div class="hero-section mb-5">
    <div class="hero-content position-relative" style="z-index: 1;">
        <h1 class="display-4 fw-bold text-white mb-3">
            Discover Amazing Stories
        </h1>
        <p class="lead text-white-50 mb-4">
            Explore insightful articles, tutorials, and thoughts from our community of writers.
        </p>
        
        <!-- Search & Filter Form -->
        <form method="get" asp-action="Index" class="row justify-content-center g-3 mt-4" id="filterForm">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-folder"></i>
                    </span>
                    <select class="form-select" name="categoryID" id="categorySelect">
                        <option value="">All Categories</option>
                        @foreach (var category in ViewBag.Categories)
                        {
                            <option value="@category.Id"
                                selected="@(currentCategory == category.Id.ToString())">
                                @category.Name
                            </option>
                        }
                    </select>
                </div>
            </div>

            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="search" name="search" class="form-control" 
                           placeholder="Search posts by title or content..."
                           value="@currentSearch" id="searchInput" />
                </div>
            </div>

            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-funnel me-1"></i> Filter
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Stats Bar -->
<div class="row mb-4">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div class="d-flex align-items-center gap-3">
                <span class="badge bg-primary fs-6 px-3 py-2">
                    <i class="bi bi-file-earmark-text me-1"></i>
                    @Model.Count() Posts
                </span>
                @if (!string.IsNullOrEmpty(currentCategory) || !string.IsNullOrEmpty(currentSearch))
                {
                    <a href="@Url.Action("Index", "Post")" class="btn btn-outline-danger btn-sm">
                        <i class="bi bi-x-lg me-1"></i>Clear Filters
                    </a>
                }
            </div>
            
            @if (User.IsInRole("Author") || User.IsInRole("Admin"))
            {
                <a class="btn btn-primary" asp-action="Create" asp-controller="Post">
                    <i class="bi bi-plus-lg me-1"></i> Create New Post
                </a>
            }
        </div>
    </div>
</div>

<!-- Posts Grid -->
<div id="postsContainer">
    <partial name="_PostListPartial" model="Model" />
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function(){
            const form = $('#filterForm');
            let debounceTimer;

            form.on('submit', function(e){
                e.preventDefault();
                loadPosts();
            });

            $('#searchInput').on('input', function() {
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(function() {
                    loadPosts();
                }, 300);
            });

            $('#categorySelect').on('change', function() {
                loadPosts();
            });

            function loadPosts() {
                const formData = form.serialize();
                $.ajax({
                    url: '@Url.Action("Index", "Post")',
                    type: 'GET',
                    data: formData,
                    success: function(data) {
                        $('#postsContainer').html(data);
                    },
                });
            }
        });
    </script>
}

