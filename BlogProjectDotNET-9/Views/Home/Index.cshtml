@model HomeViewModel
@using BlogProjectDotNET_9.Helper
@{
    ViewData["Title"] = "Home Page";
    var categoryIcons = new[] { "bi-lightbulb", "bi-code-slash", "bi-book", "bi-palette", "bi-globe", "bi-cpu", "bi-rocket", "bi-heart" };
}

@if (Model.SliderPosts.Any(p => p.Author != null && p.Author.IsApproved))
{
    <div id="postCarousel" class="carousel slide mb-5 hero-carousel" data-bs-ride="carousel" data-bs-interval="4000">
        <div class="carousel-inner rounded-4 overflow-hidden">
            @{ var index = 0; }
            @foreach (var post in Model.SliderPosts.Where(p => p.Author != null && p.Author.IsApproved))
            {
                <div class="carousel-item @(index == 0 ? "active" : "")">
                    <div class="carousel-image-wrapper">
                        <img src="@post.FeatureImagePath" class="d-block w-100" alt="@post.Title" />
                        <div class="carousel-overlay"></div>
                    </div>
                    <div class="carousel-caption">
                        <span class="category-pill">@post.Category?.Name</span>
                        <h2 class="carousel-title">@post.Title</h2>
                        @{
                            var strippedContent1 = RemoveHtmlTagHelper.RemoveHtmlTags(post.Content ?? "");
                        }
                        <p class="carousel-desc">
                            @(strippedContent1.Length > 150 ? strippedContent1.Substring(0, 150) + "..." : strippedContent1)
                        </p>
                        <a href="/Post/Details/@post.Id" class="btn btn-primary btn-lg">
                            <i class="bi bi-arrow-right me-2"></i>Read Article
                        </a>
                    </div>
                </div>
                index++;
            }
        </div>

        <button class="carousel-control-prev" type="button" data-bs-target="#postCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#postCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
        
        <div class="carousel-indicators">
            @for (int i = 0; i < Model.SliderPosts.Where(p => p.Author != null && p.Author.IsApproved).Count(); i++)
            {
                <button type="button" data-bs-target="#postCarousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")" aria-current="@(i == 0 ? "true" : "false")"></button>
            }
        </div>
    </div>
}

<div class="container-fluid px-4">
    <!-- Top Posts Section -->
    <div class="section-header mb-4">
        <h2 class="section-title">
            <i class="bi bi-fire me-2"></i>Top Posts
        </h2>
        <p class="section-subtitle">Featured articles from our community</p>
    </div>
    
    <div class="row g-4 mb-5">
        @foreach (var post in Model.SliderPosts.Where(p => p.Author != null && p.Author.IsApproved))
        {
            <div class="col-lg-4 col-md-6">
                <article class="post-card-home">
                    <div class="post-image-wrapper">
                        <img src="@post.FeatureImagePath" alt="@post.Title" />
                        <div class="post-category-badge">@post.Category?.Name</div>
                        <div class="post-image-overlay">
                            <a href="/Post/Details/@post.Id" class="btn btn-primary">
                                <i class="bi bi-eye me-1"></i>Read
                            </a>
                        </div>
                    </div>
                    <div class="post-content">
                        <h4 class="post-title-home">
                            <a href="/Post/Details/@post.Id">@post.Title</a>
                        </h4>
                        @{
                            var strippedContent2 = RemoveHtmlTagHelper.RemoveHtmlTags(post.Content ?? "");
                        }
                        <p class="post-excerpt">
                            @(strippedContent2.Length > 120 ? strippedContent2.Substring(0, 120) + "..." : strippedContent2)
                        </p>
                        <div class="post-meta-home">
                            <div class="author-info-home">
                                <div class="author-avatar-small">
                                    <i class="bi bi-person"></i>
                                </div>
                                <span>@post.Author?.FullName</span>
                            </div>
                            <span class="post-date">
                                <i class="bi bi-calendar3 me-1"></i>@post.PublishedDate.ToString("MMM dd")
                            </span>
                        </div>
                    </div>
                </article>
            </div>
        }
    </div>

    <!-- Recent Posts Section -->
    @if (Model.RecentPosts.Any(p => p.Author != null && p.Author.IsApproved))
    {
        <div class="section-header mb-4">
            <h2 class="section-title">
                <i class="bi bi-clock-history me-2"></i>Recent Posts
            </h2>
            <p class="section-subtitle">Latest articles from our writers</p>
        </div>
        
        <div class="row g-4 mb-5">
            @foreach (var post in Model.RecentPosts.Where(p => p.Author != null && p.Author.IsApproved))
            {
                <div class="col-lg-4 col-md-6">
                    <article class="post-card-home compact">
                        <div class="post-image-wrapper">
                            <img src="@post.FeatureImagePath" alt="@post.Title" />
                            <div class="post-category-badge">@post.Category?.Name</div>
                        </div>
                        <div class="post-content">
                            <h5 class="post-title-home">
                                <a href="/Post/Details/@post.Id">@post.Title</a>
                            </h5>
                            @{
                                var strippedContent3 = RemoveHtmlTagHelper.RemoveHtmlTags(post.Content ?? "");
                            }
                            <p class="post-excerpt">
                                @(strippedContent3.Length > 80 ? strippedContent3.Substring(0, 80) + "..." : strippedContent3)
                            </p>
                            <div class="post-meta-home">
                                <span class="post-date">
                                    <i class="bi bi-calendar3 me-1"></i>@post.PublishedDate.ToString("MMM dd, yyyy")
                                </span>
                            </div>
                        </div>
                    </article>
                </div>
            }
        </div>
    }

    <!-- Categories Section -->
    <div class="categories-section">
        <div class="section-header mb-4">
            <h2 class="section-title">
                <i class="bi bi-grid me-2"></i>Explore Categories
            </h2>
            <p class="section-subtitle">Browse articles by topic</p>
        </div>
        
        <div class="row g-4">
            @{ var catIndex = 0; }
            @foreach (var category in Model.Categories)
            {
                var icon = categoryIcons[catIndex % categoryIcons.Length];
                var gradientClass = new[] { "gradient-purple", "gradient-blue", "gradient-green", "gradient-orange", "gradient-pink", "gradient-teal" }[catIndex % 6];
                
                <div class="col-lg-4 col-md-6">
                    <a href="/Post?categoryID=@category.Id" class="category-card @gradientClass">
                        <div class="category-icon">
                            <i class="bi @icon"></i>
                        </div>
                        <div class="category-content">
                            <h4 class="category-name">@category.Name</h4>
                            <p class="category-description">@category.Description</p>
                        </div>
                        <div class="category-arrow">
                            <i class="bi bi-arrow-right"></i>
                        </div>
                    </a>
                </div>
                catIndex++;
            }
        </div>
    </div>
</div>

<style>
    /* Hero Carousel */
    .hero-carousel {
        border-radius: var(--radius-xl);
        overflow: hidden;
        box-shadow: var(--shadow-lg), 0 0 60px rgba(124, 58, 237, 0.2);
    }
    
    .carousel-image-wrapper {
        position: relative;
        height: 500px;
    }
    
    .carousel-image-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    
    .carousel-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.3) 50%, transparent 100%);
    }
    
    .carousel-caption {
        position: absolute;
        bottom: 3rem;
        left: 3rem;
        right: 3rem;
        text-align: left;
        padding: 0;
    }
    
    .category-pill {
        display: inline-block;
        background: var(--gradient-primary);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: var(--radius-full);
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 1rem;
    }
    
    .carousel-title {
        font-size: 2.5rem;
        font-weight: 800;
        color: white;
        margin-bottom: 1rem;
        text-shadow: 0 2px 20px rgba(0,0,0,0.5);
    }
    
    .carousel-desc {
        font-size: 1.1rem;
        color: rgba(255,255,255,0.9);
        margin-bottom: 1.5rem;
        max-width: 600px;
    }
    
    .carousel-indicators button {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: rgba(255,255,255,0.5);
        border: none;
        margin: 0 5px;
    }
    
    .carousel-indicators button.active {
        background: var(--primary);
    }
    
    /* Section Headers */
    .section-header {
        margin-top: 2rem;
    }
    
    .section-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 0.25rem;
    }
    
    .section-subtitle {
        color: var(--text-secondary);
        margin: 0;
    }
    
    /* Post Cards */
    .post-card-home {
        background: var(--bg-card);
        border-radius: var(--radius-xl);
        overflow: hidden;
        border: 1px solid var(--border-glass);
        transition: all 0.4s ease;
    }
    
    .post-card-home:hover {
        transform: translateY(-8px);
        box-shadow: var(--shadow-lg), 0 0 40px rgba(124, 58, 237, 0.15);
        border-color: var(--primary);
    }
    
    .post-card-home .post-image-wrapper {
        position: relative;
        height: 220px;
        overflow: hidden;
    }
    
    .post-card-home.compact .post-image-wrapper {
        height: 180px;
    }
    
    .post-card-home .post-image-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }
    
    .post-card-home:hover .post-image-wrapper img {
        transform: scale(1.1);
    }
    
    .post-category-badge {
        position: absolute;
        top: 1rem;
        left: 1rem;
        background: rgba(0,0,0,0.7);
        backdrop-filter: blur(10px);
        color: white;
        padding: 0.375rem 0.75rem;
        border-radius: var(--radius-full);
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
    }
    
    .post-image-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(124, 58, 237, 0.8), rgba(6, 182, 212, 0.8));
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s ease;
    }
    
    .post-card-home:hover .post-image-overlay {
        opacity: 1;
    }
    
    .post-content {
        padding: 1.25rem;
    }
    
    .post-title-home {
        font-weight: 700;
        margin-bottom: 0.75rem;
        line-height: 1.4;
    }
    
    .post-title-home a {
        color: var(--text-primary);
        text-decoration: none;
        transition: color 0.2s ease;
    }
    
    .post-title-home a:hover {
        color: var(--primary-light);
    }
    
    .post-excerpt {
        color: var(--text-secondary);
        font-size: 0.9rem;
        line-height: 1.6;
        margin-bottom: 1rem;
    }
    
    .post-meta-home {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 1rem;
        border-top: 1px solid var(--border-color);
    }
    
    .author-info-home {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-secondary);
        font-size: 0.85rem;
    }
    
    .author-avatar-small {
        width: 28px;
        height: 28px;
        background: var(--gradient-primary);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 0.75rem;
    }
    
    .post-date {
        color: var(--text-muted);
        font-size: 0.8rem;
    }
    
    /* Categories Section */
    .categories-section {
        padding: 3rem 0;
    }
    
    .category-card {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        padding: 1.5rem;
        background: var(--bg-card);
        border-radius: var(--radius-xl);
        border: 1px solid var(--border-glass);
        text-decoration: none;
        transition: all 0.4s ease;
        position: relative;
        overflow: hidden;
    }
    
    .category-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 4px;
        height: 100%;
        transition: width 0.3s ease;
    }
    
    .category-card.gradient-purple::before { background: linear-gradient(180deg, #7c3aed, #a78bfa); }
    .category-card.gradient-blue::before { background: linear-gradient(180deg, #3b82f6, #60a5fa); }
    .category-card.gradient-green::before { background: linear-gradient(180deg, #10b981, #34d399); }
    .category-card.gradient-orange::before { background: linear-gradient(180deg, #f97316, #fb923c); }
    .category-card.gradient-pink::before { background: linear-gradient(180deg, #ec4899, #f472b6); }
    .category-card.gradient-teal::before { background: linear-gradient(180deg, #06b6d4, #22d3ee); }
    
    .category-card:hover {
        transform: translateX(8px);
        border-color: var(--primary);
        box-shadow: var(--shadow-lg);
    }
    
    .category-card:hover::before {
        width: 6px;
    }
    
    .category-icon {
        width: 56px;
        height: 56px;
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }
    
    .gradient-purple .category-icon { background: rgba(124, 58, 237, 0.15); color: #a78bfa; }
    .gradient-blue .category-icon { background: rgba(59, 130, 246, 0.15); color: #60a5fa; }
    .gradient-green .category-icon { background: rgba(16, 185, 129, 0.15); color: #34d399; }
    .gradient-orange .category-icon { background: rgba(249, 115, 22, 0.15); color: #fb923c; }
    .gradient-pink .category-icon { background: rgba(236, 72, 153, 0.15); color: #f472b6; }
    .gradient-teal .category-icon { background: rgba(6, 182, 212, 0.15); color: #22d3ee; }
    
    .category-content {
        flex: 1;
    }
    
    .category-name {
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 0.375rem;
        font-size: 1.1rem;
    }
    
    .category-description {
        color: var(--text-secondary);
        font-size: 0.875rem;
        margin: 0;
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    
    .category-arrow {
        width: 40px;
        height: 40px;
        background: var(--bg-tertiary);
        border-radius: var(--radius-full);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-muted);
        transition: all 0.3s ease;
        flex-shrink: 0;
    }
    
    .category-card:hover .category-arrow {
        background: var(--primary);
        color: white;
        transform: translateX(4px);
    }
    
    /* Responsive */
    @@media (max-width: 768px) {
        .carousel-image-wrapper {
            height: 350px;
        }
        
        .carousel-title {
            font-size: 1.5rem;
        }
        
        .carousel-desc {
            font-size: 0.9rem;
        }
        
        .carousel-caption {
            left: 1.5rem;
            right: 1.5rem;
            bottom: 2rem;
        }
    }
</style>
