@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@{
    var user = await UserManager.GetUserAsync(User);
    var fullName = user?.FullName ?? "User";
    var profileImage = user?.ProfilePictureUrl ?? "/images/default.jpg";
    var userId = user?.Id;
}

<nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container">
        <!-- Brand Logo -->
        <a class="navbar-brand d-flex align-items-center gap-2" asp-action="Index" asp-controller="Post">
            <div class="brand-icon">
                <i class="bi bi-journal-richtext"></i>
            </div>
            <span>Blogify</span>
        </a>

        <!-- Mobile Toggle -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNavbar">
            <!-- Main Navigation -->
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Post" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                       asp-controller="Post" asp-action="Index">
                        <i class="bi bi-house-door me-1"></i>Home
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="bi bi-info-circle me-1"></i>About
                    </a>
                </li>

                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")" 
                           asp-controller="Admin" asp-action="Dashboard">
                            <i class="bi bi-speedometer2 me-1"></i>Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")" 
                           asp-controller="Category" asp-action="Index">
                            <i class="bi bi-folder me-1"></i>Categories
                        </a>
                    </li>
                }

                @if (User.IsInRole("Author"))
                {
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "MyPosts" ? "active" : "")" 
                           asp-controller="Post" asp-action="MyPosts">
                            <i class="bi bi-file-earmark-text me-1"></i>My Posts
                        </a>
                    </li>
                }
            </ul>

            <!-- Right Side Actions -->
            <div class="d-flex align-items-center gap-2">
                @if (!User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-sm px-3">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Login
                    </a>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-sm px-3">
                        <i class="bi bi-person-plus me-1"></i>Register
                    </a>
                }
                else
                {
                    @if (User.IsInRole("Author"))
                    {
                        <a asp-controller="Post" asp-action="Create" class="btn btn-primary btn-sm px-3 me-2">
                            <i class="bi bi-plus-lg me-1"></i>New Post
                        </a>
                    }
                    
                    <div class="dropdown">
                        <a class="user-dropdown d-flex align-items-center text-decoration-none dropdown-toggle" 
                           href="#" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            <div class="user-avatar">
                                <img src="@profileImage" alt="Profile" class="rounded-circle" width="36" height="36" style="object-fit: cover; border: 2px solid var(--primary);">
                            </div>
                            <div class="user-info d-none d-md-block ms-2">
                                <span class="user-name">@fullName</span>
                            </div>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                            <li class="dropdown-header px-3 py-2">
                                <div class="d-flex align-items-center gap-2">
                                    <img src="@profileImage" alt="Profile" class="rounded-circle" width="40" height="40" style="object-fit: cover;">
                                    <div>
                                        <div class="fw-semibold text-white">@fullName</div>
                                        <small class="text-muted">@(user?.Email ?? "")</small>
                                    </div>
                                </div>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item" asp-controller="Account" asp-action="Profile" asp-route-id="@userId">
                                    <i class="bi bi-person me-2"></i>My Profile
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-controller="Account" asp-action="EditProfile">
                                    <i class="bi bi-gear me-2"></i>Settings
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form method="post" asp-controller="Account" asp-action="Logout" class="d-inline w-100">
                                    <button class="dropdown-item text-danger w-100 text-start" type="submit">
                                        <i class="bi bi-box-arrow-right me-2"></i>Logout
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
            </div>
        </div>
    </div>
</nav>

<style>
    .brand-icon {
        width: 36px;
        height: 36px;
        background: var(--gradient-primary);
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        color: white;
        box-shadow: 0 4px 15px rgba(124, 58, 237, 0.4);
    }
    
    .user-dropdown {
        background: var(--glass-bg);
        padding: 0.375rem 0.75rem;
        border-radius: var(--radius-full);
        border: 1px solid var(--border-color);
        transition: var(--transition-base);
    }
    
    .user-dropdown:hover {
        border-color: var(--primary);
        background: rgba(124, 58, 237, 0.1);
    }
    
    .user-name {
        color: var(--text-primary);
        font-weight: 500;
        font-size: 0.875rem;
    }
    
    .dropdown-header {
        background: var(--bg-tertiary);
        border-radius: var(--radius-md) var(--radius-md) 0 0;
    }
</style>
